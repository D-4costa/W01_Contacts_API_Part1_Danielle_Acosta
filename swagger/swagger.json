{
  "openapi": "3.0.0",
  "info": {
    "title": "Contacts API",
    "version": "1.0.0",
    "description": "API for managing contacts and tasks"
  },
  "servers": [
    {
      "url": "https://w01-contacts-api-part1-danielle-acosta.onrender.com"
    }
  ],
  "paths": {
    "/contacts": {
      "get": {
        "summary": "Get all contacts",
        "responses": {
          "200": {
            "description": "List of contacts"
          }
        }
      },
      "post": {
        "summary": "Create a new contact",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "firstName",
                  "lastName",
                  "email",
                  "favoriteColor",
                  "birthday"
                ],
                "properties": {
                  "firstName": { "type": "string", "example": "Danielle" },
                  "lastName": { "type": "string", "example": "Acosta" },
                  "email": { "type": "string", "example": "danielle@example.com" },
                  "favoriteColor": { "type": "string", "example": "Blue" },
                  "birthday": { "type": "string", "example": "1998-05-10" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Contact created successfully" },
          "400": { "description": "Invalid input data" }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "summary": "Get contact by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the contact",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Contact found" },
          "404": { "description": "Contact not found" }
        }
      },
      "put": {
        "summary": "Update a contact",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the contact",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "firstName",
                  "lastName",
                  "email",
                  "favoriteColor",
                  "birthday"
                ],
                "properties": {
                  "firstName": { "type": "string", "example": "Danielle" },
                  "lastName": { "type": "string", "example": "Acosta" },
                  "email": { "type": "string", "example": "danielle@example.com" },
                  "favoriteColor": { "type": "string", "example": "Green" },
                  "birthday": { "type": "string", "example": "1998-05-10" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Contact updated successfully" },
          "404": { "description": "Contact not found" }
        }
      },
      "delete": {
        "summary": "Delete a contact",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the contact",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Contact deleted successfully" },
          "404": { "description": "Contact not found" }
        }
      }
    },

    "/tasks": {
      "get": {
        "summary": "Get all tasks",
        "responses": {
          "200": {
            "description": "List of tasks"
          }
        }
      },
      "post": {
        "summary": "Create a new task",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "description", "status"],
                "properties": {
                  "title": { "type": "string", "example": "Homework" },
                  "description": { "type": "string", "example": "Finish API project" },
                  "status": { "type": "string", "example": "pending" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Task created successfully" },
          "400": { "description": "Invalid input data" }
        }
      }
    },
    "/tasks/{id}": {
      "get": {
        "summary": "Get task by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the task",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Task found" },
          "404": { "description": "Task not found" }
        }
      },
      "put": {
        "summary": "Update a task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the task",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "description", "status"],
                "properties": {
                  "title": { "type": "string", "example": "Homework" },
                  "description": { "type": "string", "example": "Finish API project" },
                  "status": { "type": "string", "example": "completed" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Task updated successfully" },
          "404": { "description": "Task not found" }
        }
      },
      "delete": {
        "summary": "Delete a task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the task",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Task deleted successfully" },
          "404": { "description": "Task not found" }
        }
      }
    }
  }
}
